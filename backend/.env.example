# Backend — App BiT (copie para .env e preencha; .env NÃO é commitado)

# IA (Google Gemini)
AI_PROVIDER=mock                 # mock | gemini  (mock = sem chave)
AI_API_KEY=                      # chave do Gemini — só local / painel do Render
AI_MODEL=gemini-3.5-flash        # modelo (ver doc oficial do Gemini)

# CORS / servidor
FRONTEND_ORIGIN=http://localhost:5173
PORT=8000
